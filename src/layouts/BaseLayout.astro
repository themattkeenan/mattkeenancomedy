---
import SEOHead from '../components/seo/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead {...props} />
    <slot name="head" />
  </head>
  <body class="bg-brand-black text-brand-white min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <slot name="scripts" />
  </body>
</html>
