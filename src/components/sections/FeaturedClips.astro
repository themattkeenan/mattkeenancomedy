---
import { getFeaturedClips, media } from '../../data/media';
import VideoCard from '../ui/VideoCard.astro';

const clips = getFeaturedClips(3);
const hasAnyMedia = media.length > 0;
---

{hasAnyMedia && clips.length > 0 && (
  <section class="section" id="media">
    <div class="container-site">
      <div class="flex items-end justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-white" style="font-family: var(--font-heading);">
          Clips
        </h2>
        <a href="/media" class="link-arrow text-sm text-brand-grey-400 hover:text-brand-white">
          See all →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {clips.map((clip) => (
          <VideoCard clip={clip} />
        ))}
      </div>
    </div>
  </section>
)}
