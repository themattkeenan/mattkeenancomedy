---
import { getStartHereClip, getYouTubeThumbnail } from '../../data/media';

const clip = getStartHereClip();
---

{clip && (
  <section class="bg-brand-grey-900 border-y border-brand-grey-700 section-sm" id="start-here">
    <div class="container-site">
      <div class="flex flex-col md:flex-row md:items-center gap-8">
        <!-- Label -->
        <div class="md:w-1/3 flex-shrink-0">
          <p class="text-brand-red text-xs uppercase tracking-widest mb-2" style="font-family: var(--font-mono);">
            New here?
          </p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-white mb-3" style="font-family: var(--font-heading);">
            Start with this.
          </h2>
          <p class="text-brand-grey-400 text-sm leading-relaxed">
            One clip. Best introduction. No commitment required.
          </p>
        </div>

        <!-- Featured clip -->
        <div class="flex-1">
          <div class="relative group">
            <!-- Thumbnail with play overlay -->
            <div class="relative aspect-video bg-brand-grey-700 overflow-hidden cursor-pointer" id="start-here-thumb">
              <img
                src={clip.thumbnailUrl || getYouTubeThumbnail(clip.embedUrl)}
                alt={clip.title}
                width="640"
                height="360"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <!-- Red overlay on hover -->
              <div class="absolute inset-0 bg-brand-red opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
              <!-- Play button -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-16 h-16 rounded-full bg-brand-red flex items-center justify-center shadow-lg transition-transform duration-200 group-hover:scale-110">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="white">
                    <path d="M6.5 4.5l10 5.5-10 5.5V4.5z" />
                  </svg>
                </div>
              </div>
            </div>

            <!-- Embed (shown on click) -->
            <div class="hidden aspect-video" id="start-here-embed">
              <iframe
                src={clip.embedUrl}
                title={clip.title}
                width="100%"
                height="100%"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="w-full h-full"
              ></iframe>
            </div>

            <!-- Clip info -->
            <div class="mt-3 flex items-center justify-between">
              <p class="text-brand-white font-heading font-bold text-sm" style="font-family: var(--font-heading);">
                {clip.title}
              </p>
              {clip.duration && (
                <span class="text-brand-grey-400 text-xs" style="font-family: var(--font-mono);">
                  {clip.duration}
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  const thumb = document.getElementById('start-here-thumb');
  const embed = document.getElementById('start-here-embed');

  thumb?.addEventListener('click', () => {
    thumb.classList.add('hidden');
    embed?.classList.remove('hidden');
  });
</script>
