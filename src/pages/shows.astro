---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShowCard from '../components/ui/ShowCard.astro';
import { getUpcomingShows, groupShowsByMonth } from '../data/shows';

const upcoming = getUpcomingShows();
const groupedShows = groupShowsByMonth(upcoming);
---

<BaseLayout
  title="Shows"
  description="Upcoming stand-up shows and tour dates for Matt Keenan. Find out where to catch him live."
>
  <!-- Page header -->
  <div class="page-header">
    <div class="container-site">
      <p class="text-brand-red text-xs uppercase tracking-widest mb-4" style="font-family: var(--font-mono);">
        Live
      </p>
      <h1
        class="font-heading font-bold text-brand-white mb-3"
        style="font-family: var(--font-heading); font-size: clamp(2.5rem, 6vw, 4.5rem);"
      >
        Shows
      </h1>
      <p class="text-brand-grey-400 text-lg">
        Where to find me, live.
      </p>
    </div>
  </div>

  <div class="section">
    <div class="container-site">
      {upcoming.length > 0 ? (
        <!-- Show list grouped by month -->
        <div class="flex flex-col gap-10">
          {Array.from(groupedShows.entries()).map(([month, monthShows]) => (
            <div>
              <h2
                class="text-brand-grey-400 text-xs uppercase tracking-widest mb-4"
                style="font-family: var(--font-mono);"
              >
                {month}
              </h2>
              <ul>
                {monthShows.map((show) => (
                  <ShowCard show={show} />
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <!-- Empty state — in Matt's voice -->
        <div class="max-w-lg">
          <p
            class="text-brand-white font-bold mb-3"
            style="font-family: var(--font-heading); font-size: clamp(1.5rem, 4vw, 2.5rem);"
          >
            Nothing on the calendar right now.
          </p>
          <p class="text-brand-grey-400 text-lg mb-8">
            That's not a bit. I'm working on it.
          </p>

          <!-- Email signup nudge -->
          <form
            name="show-updates"
            method="POST"
            action="/thank-you"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="flex flex-col sm:flex-row gap-3 max-w-sm"
          >
            <input type="hidden" name="form-name" value="show-updates" />
            <div class="hidden" aria-hidden="true">
              <input name="bot-field" type="text" tabindex="-1" autocomplete="off" />
            </div>
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              class="field flex-1"
            />
            <button type="submit" class="btn btn-primary flex-shrink-0">
              Notify me
            </button>
          </form>
          <p class="text-brand-grey-400 text-xs mt-3">
            Get notified when new shows are announced. No spam. Just dates.
          </p>
        </div>
      )}

      <!-- Private bookings — always shown -->
      <div class="mt-16 pt-12 border-t border-brand-grey-700">
        <div class="max-w-xl">
          <p class="text-brand-grey-400 text-xs uppercase tracking-widest mb-3" style="font-family: var(--font-mono);">
            Private bookings
          </p>
          <h2 class="text-brand-white font-bold text-2xl md:text-3xl mb-3" style="font-family: var(--font-heading);">
            Looking for a private show or corporate event?
          </h2>
          <p class="text-brand-grey-100 mb-6">
            I do those. They tend to go well.
          </p>
          <a href="/contact" class="btn btn-ghost-red">
            Get in touch →
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
